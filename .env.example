# ========================================================
# PaiCLI Demo 配置文件
# ========================================================
#
# 用法：
#   1. 复制本文件为 .env
#   2. 按需填写下面的配置项
#   3. 未填写的项会回退到代码默认值
#
# 配置优先级（高 → 低）：
#   JVM 系统属性（-D）> OS 环境变量 > .env 文件 > 代码默认值
#

# ==================== LLM 对话模型 ====================

# 智谱 GLM API 密钥（必填）
# 从 https://open.bigmodel.cn 获取
GLM_API_KEY=your_glm_api_key_here

# ==================== Embedding 模型 ====================

# Embedding 后端选择：
#   ollama  — 本地 Ollama 部署（默认）
#   zhipu   — 智谱 GLM 远程 API（推荐，无需本地部署）
#   openai  — OpenAI 或其他 OpenAI 兼容服务
EMBEDDING_PROVIDER=zhipu

# Embedding 模型名称
#   ollama 默认: nomic-embed-text:latest
#   zhipu 推荐:  embedding-3
EMBEDDING_MODEL=embedding-3

# Embedding API 基地址（可选，不填则自动推断）
#   ollama:  http://localhost:11434
#   zhipu:   https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Embedding API 密钥（可选）
# 不填时自动使用 GLM_API_KEY 的值
# EMBEDDING_API_KEY=your_embedding_api_key_here
